<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>404 – Page Not Found · ClubXplore</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="/css/404.css" />
  </head>
  <body>

    <div class="nf-page">
      <!-- background blobs -->
      <div class="nf-blob nf-blob--1"></div>
      <div class="nf-blob nf-blob--2"></div>

      <div class="nf-card">

        <!-- TV illustration -->
        <div class="nf-tv-wrap">
          <div class="nf-tv">
            <!-- antenna -->
            <div class="nf-antenna">
              <div class="nf-ant-left"></div>
              <div class="nf-ant-right"></div>
              <div class="nf-ant-base"></div>
            </div>
            <!-- screen -->
            <div class="nf-screen-wrap">
              <div class="nf-screen">
                <div class="nf-scanlines"></div>
                <div class="nf-screen-text">NOT FOUND</div>
              </div>
            </div>
            <!-- controls -->
            <div class="nf-controls">
              <div class="nf-knob"></div>
              <div class="nf-knob nf-knob--sm"></div>
              <div class="nf-vents">
                <span></span><span></span><span></span>
              </div>
            </div>
            <!-- stand -->
            <div class="nf-stand">
              <div class="nf-stand__leg"></div>
              <div class="nf-stand__base"></div>
              <div class="nf-stand__leg"></div>
            </div>
          </div>
        </div>

        <!-- text -->
        <div class="nf-code">404</div>
        <h1 class="nf-title">Page not found</h1>
        <p class="nf-sub">The page you're looking for doesn't exist or has been moved.</p>

        <!-- actions -->
        <div class="nf-actions">
          <a href="/" class="nf-btn nf-btn--primary">
            <i class="bi bi-house"></i> Go home
          </a>
          <button onclick="history.back()" class="nf-btn nf-btn--outline">
            <i class="bi bi-arrow-left"></i> Go back
          </button>
        </div>

        <!-- quick links -->
        <div class="nf-links">
          <span>Try:</span>
          <a href="/login">College login</a>
          <a href="/clubRegistration/login">Club login</a>
          <a href="/collegeRegistration/signup">Sign up</a>
        </div>

      </div>
    </div>

  </body>
</html>
