<%- include("../layouts/boilerplateWN") %>
<link rel="stylesheet" href="/css/auth.css" />
<script>document.body.classList.add('auth-bg');</script>

<div class="auth-page auth-page--wide">
  <div class="auth-card">

    <a href="/" class="auth-brand">
      <div class="auth-brand__icon auth-brand__icon--club"><i class="bi bi-trophy"></i></div>
      ClubXplore
    </a>

    <h1 class="auth-title">Create a new club</h1>
    <p class="auth-sub">Register your club under your college</p>

    <form id="clubRegistrationForm" method="post" action="/clubRegistration"
      enctype="multipart/form-data" class="auth-form needs-validation" novalidate>

      <div class="auth-section-label">Club info</div>

      <div class="auth-field">
        <label class="auth-label">Club name</label>
        <div class="auth-input-wrap">
          <i class="bi bi-trophy auth-field__icon"></i>
          <input type="text" name="ClubName" class="auth-input" placeholder="e.g. Robotics Club" required />
        </div>
        <div class="auth-invalid">Club name is required.</div>
      </div>

      <div class="auth-field">
        <label class="auth-label">Branch name</label>
        <div class="auth-input-wrap">
          <i class="bi bi-diagram-2 auth-field__icon"></i>
          <input type="text" name="branchName" class="auth-input" placeholder="e.g. CSE, ECE" required />
        </div>
        <div class="auth-invalid">Branch name is required.</div>
      </div>

      <div class="auth-field">
        <label class="auth-label">Club description</label>
        <div class="auth-input-wrap" style="align-items:flex-start">
          <i class="bi bi-text-paragraph auth-field__icon" style="top:.85rem;position:absolute"></i>
          <textarea name="clubDescription" class="auth-input" rows="3"
            style="padding-top:.75rem;resize:vertical;min-height:80px" placeholder="What does your club do?" required></textarea>
        </div>
        <div class="auth-invalid">Description is required.</div>
      </div>

      <div class="auth-field">
        <label class="auth-label">Established year</label>
        <div class="auth-input-wrap">
          <i class="bi bi-calendar auth-field__icon"></i>
          <input type="text" name="establishedYear" class="auth-input" placeholder="e.g. 2015" required />
        </div>
        <div class="auth-invalid">Established year is required.</div>
      </div>

      <div class="auth-field">
        <label class="auth-label">Club logo</label>
        <div class="auth-file-wrap">
          <label class="auth-file-label" for="ClubLogo">
            <i class="bi bi-cloud-upload"></i>
            <span id="clubLogoText">Click to upload logo</span>
          </label>
          <input id="ClubLogo" name="ClubLogo" type="file" class="auth-file-input"
            accept="image/*" required onchange="updateFileName('ClubLogo','clubLogoText')" />
        </div>
        <div class="auth-invalid">Please upload the club logo.</div>
      </div>

      <div class="auth-field">
        <label class="auth-label">Achievements <span style="color:#94a3b8;font-weight:400">(optional)</span></label>
        <div class="auth-input-wrap" style="align-items:flex-start">
          <i class="bi bi-award auth-field__icon" style="top:.85rem;position:absolute"></i>
          <textarea name="Achievements" class="auth-input" rows="2"
            style="padding-top:.75rem;resize:vertical" placeholder="Notable achievements..."></textarea>
        </div>
      </div>

      <!-- Faculty Coordinators -->
      <div class="auth-section-label" style="margin-top:.5rem">Faculty coordinators</div>
      <div id="facultyList">
        <div class="auth-list-row faculty-entry">
          <input type="text" name="facultyCoordinators[0][name]" class="auth-input" placeholder="Name" required />
          <input type="email" name="facultyCoordinators[0][email]" class="auth-input" placeholder="Email" required />
          <input type="text" name="facultyCoordinators[0][phoneNumber]" class="auth-input" placeholder="Phone" required />
        </div>
      </div>
      <button type="button" class="auth-add-btn" onclick="addRow('faculty')"><i class="bi bi-plus"></i> Add faculty</button>

      <!-- Student Coordinators -->
      <div class="auth-section-label" style="margin-top:.5rem">Student coordinators</div>
      <div id="studentList">
        <div class="auth-list-row student-entry">
          <input type="text" name="studentCoordinators[0][name]" class="auth-input" placeholder="Name" required />
          <input type="email" name="studentCoordinators[0][email]" class="auth-input" placeholder="Email" required />
          <input type="text" name="studentCoordinators[0][phoneNumber]" class="auth-input" placeholder="Phone" required />
        </div>
      </div>
      <button type="button" class="auth-add-btn" onclick="addRow('student')"><i class="bi bi-plus"></i> Add student</button>

      <!-- Social Links -->
      <div class="auth-section-label" style="margin-top:.5rem">Social media links</div>
      <div id="socialList">
        <div class="auth-list-row auth-list-row--2col social-entry">
          <input type="text" name="socialMediaLink[0][name]" class="auth-input" placeholder="Platform" required />
          <input type="url" name="socialMediaLink[0][link]" class="auth-input" placeholder="URL" required />
        </div>
      </div>
      <button type="button" class="auth-add-btn" onclick="addRow('social')"><i class="bi bi-plus"></i> Add link</button>

      <!-- Password -->
      <div class="auth-section-label" style="margin-top:.5rem">Account</div>
      <div class="auth-field">
        <label class="auth-label" for="password">Password</label>
        <div class="auth-input-wrap">
          <i class="bi bi-lock auth-field__icon"></i>
          <input id="password" name="password" type="password" class="auth-input"
            placeholder="Set a password" required autocomplete="new-password" />
          <button type="button" class="auth-eye" onclick="togglePwd('password',this)"><i class="bi bi-eye"></i></button>
        </div>
        <div class="auth-invalid">Password is required.</div>
      </div>

      <button type="submit" class="auth-submit auth-submit--club" id="clubCreateBtn">
        <span class="auth-submit__text">Create club</span>
        <span class="auth-submit__spinner"></span>
      </button>

    </form>

    <p class="auth-footer-link">Already registered? <a href="/clubRegistration/login">Sign in</a></p>

  </div>
</div>

<script>
  let fi = 1, si = 1, soi = 1;

  function addRow(type) {
    const configs = {
      faculty: { id: 'facultyList', cls: 'faculty-entry', prefix: 'facultyCoordinators', idx: () => fi++, cols: 3 },
      student: { id: 'studentList', cls: 'student-entry', prefix: 'studentCoordinators', idx: () => si++, cols: 3 },
      social:  { id: 'socialList',  cls: 'social-entry auth-list-row--2col', prefix: 'socialMediaLink', idx: () => soi++, cols: 2 }
    };
    const c = configs[type];
    const i = c.idx();
    const div = document.createElement('div');
    div.className = 'auth-list-row ' + c.cls;
    const fields = type === 'social'
      ? [['text','name','Platform'],['url','link','URL']]
      : [['text','name','Name'],['email','email','Email'],['text','phoneNumber','Phone']];
    fields.forEach(([t, key, ph]) => {
      const inp = document.createElement('input');
      inp.type = t; inp.name = c.prefix + '[' + i + '][' + key + ']';
      inp.className = 'auth-input'; inp.placeholder = ph; inp.required = true;
      div.appendChild(inp);
    });
    const rmBtn = document.createElement('button');
    rmBtn.type = 'button'; rmBtn.className = 'auth-remove-btn';
    rmBtn.innerHTML = '<i class="bi bi-x"></i>';
    rmBtn.onclick = function() { div.remove(); };
    div.appendChild(rmBtn);
    document.getElementById(c.id).appendChild(div);
  }

  function togglePwd(id, btn) {
    const inp = document.getElementById(id);
    const ico = btn.querySelector('i');
    inp.type = inp.type === 'password' ? 'text' : 'password';
    ico.className = inp.type === 'password' ? 'bi bi-eye' : 'bi bi-eye-slash';
  }

  function updateFileName(inputId, labelId) {
    const f = document.getElementById(inputId).files[0];
    if (f) document.getElementById(labelId).textContent = f.name;
  }

  document.getElementById('clubRegistrationForm').addEventListener('submit', function() {
    if (this.checkValidity()) {
      const btn = document.getElementById('clubCreateBtn');
      btn.classList.add('loading'); btn.disabled = true;
    }
  });
</script>
