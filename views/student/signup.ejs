<%- include("../layouts/boilerplateWN") %>
<link rel="stylesheet" href="/css/auth.css" />
<script>document.body.classList.add('auth-bg');</script>

<div class="auth-page">
  <div class="auth-card">

    <a href="/" class="auth-brand">
      <div class="auth-brand__icon auth-brand__icon--student"><i class="bi bi-mortarboard"></i></div>
      ClubXplore
    </a>

    <h1 class="auth-title">Student sign up</h1>
    <p class="auth-sub">Create your student account</p>

    <form id="studentSignupForm" method="post"
      action="/college/<%= collegeId %>/studentRegistration/signup"
      novalidate class="auth-form needs-validation">

      <div class="auth-field">
        <label class="auth-label" for="studentName">Full name</label>
        <div class="auth-input-wrap">
          <i class="bi bi-person auth-field__icon"></i>
          <input type="text" id="studentName" name="studentName" class="auth-input"
            placeholder="Your full name" required />
        </div>
        <div class="auth-invalid">Please enter your name.</div>
      </div>

      <div class="auth-field">
        <label class="auth-label" for="email">Email address</label>
        <div class="auth-input-wrap">
          <i class="bi bi-envelope auth-field__icon"></i>
          <input type="email" id="email" name="email" class="auth-input"
            placeholder="you@example.com" required autocomplete="email" />
        </div>
        <div class="auth-invalid">Please enter a valid email.</div>
      </div>

      <div class="auth-otp-row">
        <div class="auth-field" style="flex:1">
          <label class="auth-label" for="otp">OTP</label>
          <div class="auth-input-wrap">
            <i class="bi bi-shield-lock auth-field__icon"></i>
            <input id="otp" name="otp" type="text" class="auth-input"
              placeholder="6-digit code" required maxlength="6" pattern="\d{6}" inputmode="numeric"
              oninput="this.value=this.value.replace(/[^0-9]/g,'').slice(0,6)" />
          </div>
        </div>
        <div style="display:flex;flex-direction:column;gap:.32rem">
          <label class="auth-label" style="visibility:hidden">.</label>
          <button type="button" class="auth-otp-btn" id="sendOtpBtn" onclick="sendOtp()">Send OTP</button>
        </div>
      </div>
      <div id="email-message" class="auth-msg"></div>

      <button type="button" class="auth-otp-btn" id="verifyOtpBtn" onclick="verifyOtpBeforeSubmit()" style="width:100%;height:42px">
        Verify OTP
      </button>
      <div id="email-otp-message" class="auth-msg"></div>

      <div class="auth-field">
        <label class="auth-label" for="regNo">Registration number</label>
        <div class="auth-input-wrap">
          <i class="bi bi-card-text auth-field__icon"></i>
          <input type="text" id="regNo" name="regNo" class="auth-input"
            placeholder="Your registration number" required />
        </div>
        <div class="auth-invalid">Please enter your registration number.</div>
      </div>

      <div class="auth-field">
        <label class="auth-label" for="password">Password</label>
        <div class="auth-input-wrap">
          <i class="bi bi-lock auth-field__icon"></i>
          <input type="password" id="password" name="password" class="auth-input"
            placeholder="Set a password" required autocomplete="new-password" />
          <button type="button" class="auth-eye" onclick="togglePwd('password',this)"><i class="bi bi-eye"></i></button>
        </div>
        <div class="auth-invalid">Please enter a password.</div>
      </div>

      <button type="submit" class="auth-submit auth-submit--student" id="stuSignupBtn">
        <span class="auth-submit__text">Create account</span>
        <span class="auth-submit__spinner"></span>
      </button>

    </form>

    <p class="auth-footer-link">Already registered? <a href="/studentRegistration/login">Sign in</a></p>

  </div>
</div>

<script>
  const apiBase = window.location.origin;

  function showMsg(id, msg, ok) {
    const el = document.getElementById(id);
    el.textContent = msg;
    el.className = 'auth-msg show ' + (ok ? 'auth-msg--success' : 'auth-msg--error');
    setTimeout(() => el.classList.remove('show'), 4000);
  }

  async function sendOtp() {
    const email = document.getElementById('email').value;
    if (!email) { showMsg('email-message', 'Enter your email first', false); return; }
    const btn = document.getElementById('sendOtpBtn');
    btn.disabled = true; btn.textContent = 'Sending...';
    try {
      const res = await fetch(apiBase + '/send-otp', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email })
      });
      const data = await res.json();
      showMsg('email-message', data.message, res.ok);
    } catch(e) { showMsg('email-message', 'Error sending OTP', false); }
    finally { btn.disabled = false; btn.textContent = 'Send OTP'; }
  }

  async function verifyOtpBeforeSubmit() {
    const email = document.getElementById('email').value;
    const otp = document.getElementById('otp').value;
    if (!otp) { showMsg('email-otp-message', 'Enter the OTP first', false); return; }
    try {
      const res = await fetch(apiBase + '/verify-otp', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, otp })
      });
      const data = await res.json();
      if (data.success) {
        showMsg('email-otp-message', 'OTP verified', true);
        document.getElementById('otp').disabled = true;
        const vBtn = document.getElementById('verifyOtpBtn');
        vBtn.disabled = true; vBtn.textContent = 'Verified';
      } else {
        showMsg('email-otp-message', data.message, false);
      }
    } catch(e) { showMsg('email-otp-message', 'Error verifying OTP', false); }
  }

  function togglePwd(id, btn) {
    const inp = document.getElementById(id);
    const ico = btn.querySelector('i');
    inp.type = inp.type === 'password' ? 'text' : 'password';
    ico.className = inp.type === 'password' ? 'bi bi-eye' : 'bi bi-eye-slash';
  }

  document.getElementById('studentSignupForm').addEventListener('submit', function(e) {
    const vBtn = document.getElementById('verifyOtpBtn');
    if (!vBtn.disabled) {
      e.preventDefault();
      showMsg('email-otp-message', 'Please verify OTP before submitting', false);
      return;
    }
    if (this.checkValidity()) {
      const btn = document.getElementById('stuSignupBtn');
      btn.classList.add('loading'); btn.disabled = true;
    }
  });
</script>
